# Pickle cache directory (optional). Defaults to data/cache/ at the repo root.
# On Railway, mount a volume at /app/data/cache and set WORDLE_CACHE_DIR=/app/data/cache
WORDLE_CACHE_DIR=

# Comma-separated browser origins allowed to call the API (in addition to localhost).
# Leave empty for Railway same-origin deploy.
CORS_ORIGINS=
