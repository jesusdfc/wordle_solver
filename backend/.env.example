# Pickle cache directory (optional). On Railway, mount a volume at /app/data/cache
# and set WORDLE_CACHE_DIR=/app/data/cache
WORDLE_CACHE_DIR=

# Comma-separated browser origins allowed to call the API (in addition to localhost).
# Leave empty on Railway same-origin deploy. For split Netlify+Render:
# Example: https://your-app.netlify.app
CORS_ORIGINS=
