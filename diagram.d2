# palabra-solver architecture (D2)
# Render: d2 --layout elk diagram.d2 diagram.svg

direction: right

data: {
  label: |md
    **data.py**
    `WordleWordsHandler`
  |
  shape: class

  load: "load() → valid words"
  normalize: "normalize() → strip accents, filter"
}

env: {
  label: |md
    **env.py**
    `WordleEnv`
  |
  shape: class

  hidden: "secret (hidden state)"
  dynamics: "pattern(secret, guess)"
  reset: "reset() → observation"
  step: "step(guess) → obs, reward, done"
}

belief: {
  label: |md
    **belief.py**
    `BeliefState`
  |
  shape: class

  posterior: "candidates (belief b(s))"
  update: "update(guess, pattern)"
  filter: "Bayesian filter over secrets"
}

agent: {
  label: |md
    **agent.py**
    `WordleAgent`
  |
  shape: class

  policy: "suggest() → action"
  entropy: "expected_entropy()"
  minimax: "minimax_worst_case()"
  solve: "solve(secret) benchmark loop"
}

cli: {
  label: |md
    **cli.py**
    `palabra` command
  |
  shape: class
}

data -> env: "valid word list"
env -> belief: "observation\n(guess + pattern)"
belief -> agent: "belief state"
agent -> env: "action\n(guess word)"
cli -> agent: "suggest / solve"
cli -> data: "load dictionary"

episode: {
  label: "Episode loop"
  style.fill: "#f5f5f5"

  reset: "env.reset()"
  act: "agent.suggest()"
  step: "env.step(guess)"
  observe: "belief.update(pattern)"
}

env.reset -> episode.reset
episode.act -> agent
episode.step -> env
episode.observe -> belief

legend: {
  label: |md
    **RL mapping**
    | Component | RL role |
    |-----------|---------|
    | `WordleEnv` | Environment (POMDP) |
    | `BeliefState` | Belief b(s) over hidden state |
    | `WordleAgent` | Policy π(b) → action |
    | `WordleWordsHandler` | Action space / dictionary |
  |
  near: bottom-right
}
