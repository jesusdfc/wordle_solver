%% palabra-solver architecture
%% Preview in VS Code (Mermaid extension), GitHub, or https://mermaid.live

flowchart LR
    data["<b>data.py</b><br/>WordleWordsHandler<br/>load() · normalize()"]
    env["<b>env.py</b><br/>WordleEnv<br/>reset() · step() · pattern()"]
    belief["<b>belief.py</b><br/>BeliefState<br/>update() · candidates"]
    agent["<b>agent.py</b><br/>WordleAgent<br/>suggest() · entropy / minimax"]
    cli["<b>cli.py</b><br/>palabra command"]

    data -->|"valid word list"| env
    env -->|"observation<br/>(guess + pattern)"| belief
    belief -->|"belief state"| agent
    agent -->|"action<br/>(guess word)"| env
    cli -->|"suggest / solve"| agent
    cli -->|"load dictionary"| data

    subgraph episode ["Episode loop"]
        direction LR
        ep_reset["env.reset()"] --> ep_act["agent.suggest()"]
        ep_act --> ep_step["env.step(guess)"]
        ep_step --> ep_observe["belief.update(pattern)"]
        ep_observe --> ep_act
    end

    env -.-> ep_reset
    agent -.-> ep_act
    env -.-> ep_step
    belief -.-> ep_observe
